{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desklings",
  "version": "0.1.0",
  "identifier": "app.desklings",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Desklings Settings",
        "url": "settings.html",
        "width": 820,
        "height": 600,
        "minWidth": 680,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "center": true,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    }
  }
}
